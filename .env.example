# ============================================
# FRESCROW — Environment Variables Template
# ============================================
# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.

# --- Server ---
PORT=8080

# --- Database ---
DB_URL=jdbc:postgresql://your-host:5432/your-db?sslmode=require
DB_USER=your_db_user
DB_PASS=your_db_password

# --- JWT (SENSITIVE) ---
JWT_SECRET=your_base64_encoded_secret_key
JWT_EXPIRATION_MS=86400000

# --- Nonce ---
NONCE_EXPIRY_SECONDS=300

# --- JPA / Debug (set to false in production) ---
JPA_DDL_AUTO=validate
JPA_SHOW_SQL=false
JPA_FORMAT_SQL=false

# --- Actuator ---
ACTUATOR_ENDPOINTS=health,info
ACTUATOR_HEALTH_DETAILS=never

# --- AI Validator (FastAPI) ---
AI_VALIDATOR_BASE_URL=https://your-fastapi-service.onrender.com
AI_GENERATE_MILESTONES_PATH=/api/v1/ai/generate-milestones
AI_EVALUATE_PATH=/api/v1/ai/evaluate

# --- Blockchain (FastAPI) ---
BLOCKCHAIN_BASE_URL=https://your-fastapi-service.onrender.com
BLOCKCHAIN_DEPLOY_CONTRACT_PATH=/api/v1/blockchain/deploy-contract
BLOCKCHAIN_GET_APP_ID_PATH=/api/v1/blockchain/get-app-id
BLOCKCHAIN_FUND_PROJECT_PATH=/api/v1/blockchain/fund-project
BLOCKCHAIN_RELEASE_MILESTONE_PATH=/api/v1/blockchain/release-milestone
